{
  "productName": "ESTELA Exam Builder",
  "version": "0.1.0",
  "identifier": "edu.ucf.estela",
  "build": {
    "frontendDist": "../frontend"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "ESTELA Exam Builder",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "visible": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  }
}
